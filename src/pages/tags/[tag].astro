---
import BaseHead from "../../components/BaseHead.astro";
import DraftBadge from "../../components/DraftBadge.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import TagList from "../../components/TagList.astro";
import { SITE_TITLE } from "../../consts";
import { getPublishedPosts, tagSlug } from "../../utils/posts";

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const tags = new Map<string, { label: string; posts: typeof posts }>();

	for (const post of posts) {
		for (const tag of post.data.tags) {
			const slug = tagSlug(tag);
			if (!tags.has(slug)) tags.set(slug, { label: tag, posts: [] });
			tags.get(slug)!.posts.push(post);
		}
	}

	return [...tags.entries()].map(([slug, { label, posts }]) => ({
		params: { tag: slug },
		props: { label, posts },
	}));
}

type Props = {
	label: string;
	posts: Awaited<ReturnType<typeof getPublishedPosts>>;
};

const { label, posts } = Astro.props;
const description = `Essays tagged “${label}”.`;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${SITE_TITLE} | ${label}`} description={description} />
  </head>
  <body>
    <Header />
    <main>
      <p class="back"><a href="/tags">← All topics</a></p>
      <h1>Tagged: {label}</h1>
      <ul class="posts">
        {
          posts.map((post) => (
            <li>
              <a href={`/essays/${post.id}/`}>
                <p class="date">
                  <FormattedDate date={post.data.pubDate} />
                  <DraftBadge draft={post.data.draft} />
                </p>
                <h2>{post.data.title}</h2>
                <p class="excerpt">{post.data.description}</p>
              </a>
              <TagList tags={post.data.tags} />
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>

<style>
  .back {
    margin: 0 0 0.5rem 0;
  }
  .back a {
    font-size: 0.9rem;
    text-decoration: none;
  }
  .posts {
    list-style: none;
    margin: 1.5rem 0 0 0;
    padding: 0;
  }
  .posts li {
    padding: 1.5rem 0;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .posts li a {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .posts h2 {
    margin: 0.2em 0;
    font-size: 1.5rem;
    color: rgb(var(--black));
  }
  .posts li a:hover h2 {
    color: var(--accent);
  }
  .date {
    margin: 0;
    color: rgb(var(--gray));
    font-size: 0.85rem;
  }
  .excerpt {
    margin: 0.3em 0 0.8em 0;
    color: rgb(var(--gray-dark));
  }
</style>
