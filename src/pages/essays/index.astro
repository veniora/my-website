---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import TagList from "../../components/TagList.astro";
import { SITE_TITLE } from "../../consts";
import { getAllTags, getDraftPosts, getPublishedPosts } from "../../utils/posts";

const posts = await getPublishedPosts();
const drafts = await getDraftPosts();
const tags = await getAllTags();
const description = "Everything I've written, newest first.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${SITE_TITLE} | Essays`} description={description} />
  </head>
  <body>
    <Header />
    <main>
      <h1>Essays</h1>

      {
        drafts.length > 0 && (
          <section class="drafts-section">
            <h2 class="drafts-heading">Drafts</h2>
            <ul class="post-list">
              {drafts.map((post) => (
                <li>
                  <time class="post-date">
                    <FormattedDate date={post.data.pubDate} />
                  </time>
                  <span class="post-title">
                    <a href={`/drafts/${post.id}/`}>{post.data.title}</a>
                  </span>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        tags.length > 0 && (
          <div class="browse">
            <span>Browse by topic:</span>
            <TagList tags={tags} />
          </div>
        )
      }

      {
        posts.length === 0 ? (
          <p>No posts yet — check back soon.</p>
        ) : (
          <ul class="post-list">
            {posts.map((post) => (
              <li>
                <time class="post-date">
                  <FormattedDate date={post.data.pubDate} />
                </time>
                <span class="post-title">
                  <a href={`/essays/${post.id}/`}>{post.data.title}</a>
                </span>
              </li>
            ))}
          </ul>
        )
      }
    </main>
    <Footer />
  </body>
</html>

<style>
  .drafts-section {
    margin-bottom: 3rem;
  }
  .drafts-heading {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--gray));
    margin: 0 0 0.5rem 0;
  }

  .browse {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6em;
    margin-bottom: 2rem;
  }
  .browse span {
    color: rgb(var(--gray));
    font-size: 0.9rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .post-list li {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 0.55rem 0;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .post-list li:last-child {
    border-bottom: 1px solid rgb(var(--gray-light));
  }
  .post-date {
    color: rgb(var(--gray));
    font-size: 0.8rem;
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 6.5rem;
    font-family: ui-monospace, 'Cascadia Code', 'Courier New', monospace;
  }
  .post-title {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .post-title a {
    color: rgb(var(--black));
    font-size: 1rem;
    line-height: 1.4;
  }
  .post-title a:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .post-list li {
      flex-direction: column;
      gap: 0.15rem;
      padding: 0.75rem 0;
    }
  }
</style>
