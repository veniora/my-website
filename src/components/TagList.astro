---
import { tagSlug } from "../utils/posts";

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{
  tags.length > 0 && (
    <ul class="tags">
      {tags.map((tag) => (
        <li>
          <a href={`/tags/${tagSlug(tag)}/`}>{tag}</a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tags li {
    margin: 0;
  }
  .tags a {
    display: inline-block;
    padding: 0.15em 0.7em;
    font-size: 0.8rem;
    line-height: 1.6;
    color: rgb(var(--gray-dark));
    background: rgb(var(--gray-light));
    border-radius: 999px;
    text-decoration: none;
    transition: 0.15s ease;
  }
  .tags a:hover {
    background: var(--accent);
    color: white;
  }
</style>
